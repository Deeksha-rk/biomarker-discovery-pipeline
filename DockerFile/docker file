# 1. Use an official Python environment
FROM python:3.9-slim

# 2. Set the working directory inside the container
WORKDIR /app

# 3. Install system dependencies needed for scientific libraries
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# 4. Copy and install your Python libraries
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 5. COPY . . (This copies your data, ML, and visualization folders into Docker)
COPY . .

# 6. Expose the port for your Streamlit dashboard
EXPOSE 8501

# 7. THE PIPELINE EXECUTION
# This runs your scripts in the specific order you provided.
# use quotes for folder names with spaces so Linux understands them.
CMD python data/data_grouped.py && \
    python "Differential Expression/diff analysis_01.py" && \
    python "Differential Expression/gene.py" && \
    python Visualization/visualization_04.py && \
    python Visualization/network_01.py && \
    python Visualization/pathway.py && \
    python "Machine Learning/shap_analysis.py" && \
    python "Biomarker Identification/biomarker_identification_02.py" && \
    streamlit run dashboard_03.py
